@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Employee Dashboard — PCMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-100 min-h-screen font-sans">


         sticky = stays at top when you scroll
         z-50   = stays on top of all other elements --}}
    <nav class="sticky top-0 z-50 bg-slate-900 shadow-lg">
        <div class="max-w-7xl mx-auto px-6 h-14 flex items-center justify-between">

            
            <div class="flex items-center gap-3">
                <span class="text-white font-bold text-lg tracking-wide">
                    PC<span class="text-sky-400">MS</span>
                </span>
                <span class="hidden sm:block text-slate-400 text-sm">IT Help Desk</span>
            </div>

           
            <div class="flex items-center gap-4">
                <span class="text-slate-400 text-sm hidden sm:block">
                    Logged in as
                    <strong class="text-slate-200 font-medium">@Session["EmployeeNumber"]</strong>
                </span>
                <a href="@Url.Action("Logout", "Account")"
                   class="border border-slate-600 text-slate-400 hover:border-red-500 hover:text-red-400
                          text-sm px-4 py-1.5 rounded-md transition-colors duration-200">
                    Logout
                </a>
            </div>

        </div>
    </nav>

    
    <main class="max-w-7xl mx-auto px-6 py-8">

        
        <div class="mb-8">
            <h1 class="text-2xl font-semibold text-slate-800">Employee Dashboard</h1>
            <p class="text-slate-500 text-sm mt-1">
                Welcome, @Session["EmployeeNumber"]. Raise or track your IT complaints below.
            </p>
        </div>

        
        <div class="bg-blue-50 border border-blue-200 border-l-4 border-l-blue-500
                    rounded-lg px-4 py-3 text-blue-800 text-sm mb-8 flex items-center gap-2">
            <span class="font-bold">ℹ</span>
            For urgent issues, contact the IT Help Desk on the internal extension.
        </div>


        
             
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3 pl-0.5">
            Service Requests
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-10">

            
            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Pending Requisitions
                </p>
                <a href="#" class="text-blue-600 hover:underline text-sm font-medium">
                    → View all pending
                </a>
            </div>

            
            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Register Service Requisition
                </p>
                <div class="flex gap-2">
                    <input type="text" placeholder="Machine No."
                           class="flex-1 text-sm border border-slate-200 rounded-lg px-3 py-2
                                  bg-slate-50 text-slate-800 placeholder-slate-400
                                  focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent" />
                    <a href="#"
                       class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium
                              px-3 py-2 rounded-lg transition-colors duration-200 whitespace-nowrap">
                        Go
                    </a>
                </div>
                <p class="text-xs text-slate-400 mt-2">Enter Machine Number</p>
            </div>

        </div>


       
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3 pl-0.5">
            Feedback &amp; Complaints
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-10">

           
            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Give Feedback
                </p>
                <div class="flex gap-2">
                    <input type="text" placeholder="Complain No."
                           class="flex-1 text-sm border border-slate-200 rounded-lg px-3 py-2
                                  bg-slate-50 text-slate-800 placeholder-slate-400
                                  focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent" />
                    <a href="#"
                       class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium
                              px-3 py-2 rounded-lg transition-colors duration-200">
                        Go
                    </a>
                </div>
            </div>

            
            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Complaint Details
                </p>
                <div class="flex gap-2">
                    <input type="text" placeholder="Complain No."
                           class="flex-1 text-sm border border-slate-200 rounded-lg px-3 py-2
                                  bg-slate-50 text-slate-800 placeholder-slate-400
                                  focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent" />
                    <a href="#"
                       class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium
                              px-3 py-2 rounded-lg transition-colors duration-200">
                        Go
                    </a>
                </div>
                <p class="text-xs text-slate-400 mt-2">By Complaint Number</p>
            </div>

            
            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Complaint Details
                </p>
                <div class="flex gap-2">
                    <input type="text" placeholder="Machine No."
                           class="flex-1 text-sm border border-slate-200 rounded-lg px-3 py-2
                                  bg-slate-50 text-slate-800 placeholder-slate-400
                                  focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent" />
                    <a href="#"
                       class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium
                              px-3 py-2 rounded-lg transition-colors duration-200">
                        Go
                    </a>
                </div>
                <p class="text-xs text-slate-400 mt-2">By Machine Number</p>
            </div>

           
            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Complaint Details (New)
                </p>
                <div class="flex gap-2">
                    <input type="text" placeholder="Machine No."
                           class="flex-1 text-sm border border-slate-200 rounded-lg px-3 py-2
                                  bg-slate-50 text-slate-800 placeholder-slate-400
                                  focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent" />
                    <a href="#"
                       class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium
                              px-3 py-2 rounded-lg transition-colors duration-200">
                        Go
                    </a>
                </div>
            </div>

            
            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Latest Complaint Status
                </p>
                <a href="#" class="text-blue-600 hover:underline text-sm font-medium">
                    → Check status
                </a>
            </div>

        </div>


        
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3 pl-0.5">
            Machine &amp; PC Info
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-10">

            
            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Update Machine Details
                </p>
                <div class="flex gap-2">
                    <input type="text" placeholder="Machine No."
                           class="flex-1 text-sm border border-slate-200 rounded-lg px-3 py-2
                                  bg-slate-50 text-slate-800 placeholder-slate-400
                                  focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent" />
                    <a href="#"
                       class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium
                              px-3 py-2 rounded-lg transition-colors duration-200">
                        Go
                    </a>
                </div>
            </div>

            
            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Get PC Info
                </p>
                <div class="flex gap-2">
                    <input type="text" placeholder="PC No."
                           class="flex-1 text-sm border border-slate-200 rounded-lg px-3 py-2
                                  bg-slate-50 text-slate-800 placeholder-slate-400
                                  focus:outline-none focus:ring-2 focus:ring-blue-400 focus:border-transparent" />
                    <a href="#"
                       class="bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium
                              px-3 py-2 rounded-lg transition-colors duration-200">
                        Go
                    </a>
                </div>
            </div>

        </div>


        
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3 pl-0.5">
            Asset Enquiry
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-10">

            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Asset Enquiry
                </p>
                <div class="flex flex-col gap-1.5">
                    <a href="#" class="text-blue-600 hover:underline text-sm font-medium">→ IP Wise</a>
                    <a href="#" class="text-blue-600 hover:underline text-sm font-medium">→ Machine Wise</a>
                </div>
            </div>

            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    IT Asset History
                </p>
                <div class="flex flex-col gap-1.5">
                    <a href="#" class="text-blue-600 hover:underline text-sm font-medium">→ Subnet Wise</a>
                    <a href="#" class="text-blue-600 hover:underline text-sm font-medium">→ Dept-Wise</a>
                </div>
            </div>

            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Dept. Wise Asset Distribution
                </p>
                <a href="#" class="text-blue-600 hover:underline text-sm font-medium">→ View Report</a>
            </div>

            <div class="bg-white border border-slate-200 rounded-xl p-5
                        hover:border-blue-400 hover:shadow-md transition-all duration-200">
                <p class="text-sm font-medium text-slate-700 flex items-center gap-2 mb-3">
                    <span class="w-1 h-4 bg-blue-500 rounded-full inline-block"></span>
                    Service Requisition Reports
                </p>
                <div class="flex flex-col gap-1.5">
                    <a href="#" class="text-blue-600 hover:underline text-sm font-medium">→ Detailed List (Period)</a>
                    <a href="#" class="text-blue-600 hover:underline text-sm font-medium">→ Brief Summary</a>
                    <a href="#" class="text-blue-600 hover:underline text-sm font-medium">→ View Feedback (Period)</a>
                </div>
            </div>

        </div>

    </main>

</body>
</html>