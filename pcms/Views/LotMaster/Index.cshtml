@model PCMS.DTOs.LotMasterDto
@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lot Master — PCMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { font-family: 'Syne', sans-serif; }
        .mono { font-family: 'JetBrains Mono', monospace; }

        .f-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            color: #64748b;
            margin-bottom: 5px;
            display: block;
        }
        .f-label .req { color: #f87171; margin-left: 2px; }

        .f-input, .f-select {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.82rem;
            width: 100%;
            background: #f8fafc;
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            padding: 8px 12px;
            color: #1e293b;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s, background 0.18s;
            appearance: none;
            -webkit-appearance: none;
        }
        .f-input:focus, .f-select:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 3px rgba(245,158,11,0.15);
            background: #fff;
        }
        .f-input.is-invalid, .f-select.is-invalid {
            border-color: #f87171;
            box-shadow: 0 0 0 3px rgba(248,113,113,0.12);
        }

        /* Lot No field gets a highlight style */
        .lot-field {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.9rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            width: 100%;
            background: #fffbeb;
            border: 2px solid #fbbf24;
            border-radius: 8px;
            padding: 8px 14px;
            color: #92400e;
            outline: none;
            transition: border-color 0.18s, box-shadow 0.18s;
        }
        .lot-field:focus {
            border-color: #f59e0b;
            box-shadow: 0 0 0 3px rgba(245,158,11,0.2);
            background: #fff;
        }
        .lot-field.is-invalid {
            border-color: #f87171;
            box-shadow: 0 0 0 3px rgba(248,113,113,0.12);
            background: #fff5f5;
        }
        .lot-field::placeholder { color: #d97706; opacity: 0.6; font-weight: 400; }

        .select-wrap { position: relative; }
        .select-wrap::after {
            content: '▾';
            position: absolute;
            right: 10px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 0.75rem;
            pointer-events: none;
        }
        input[type="date"]::-webkit-calendar-picker-indicator { opacity: 0.5; cursor: pointer; filter: invert(0.4); }

        .form-row { display: grid; gap: 16px; }
        .cols-3 { grid-template-columns: 1fr 1fr 1fr; }
        .cols-2 { grid-template-columns: 1fr 1fr; }
        .cols-1 { grid-template-columns: 1fr; }

        .section-head {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.12em;
            text-transform: uppercase;
            color: #f59e0b;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 14px;
            margin-top: 4px;
        }
        .section-head::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, #fbbf24 0%, transparent 100%);
        }

        .btn-insert {
            font-family: 'Syne', sans-serif;
            font-weight: 700;
            font-size: 0.9rem;
            letter-spacing: 0.05em;
            background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 12px 48px;
            cursor: pointer;
            transition: transform 0.15s, box-shadow 0.15s;
            box-shadow: 0 4px 14px rgba(245,158,11,0.35);
        }
        .btn-insert:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(245,158,11,0.45); }
        .btn-insert:active { transform: translateY(0); }

        /* Go search bar */
        .search-bar { display: flex; align-items: center; gap: 8px; }
        .search-input {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.82rem;
            font-weight: 600;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            width: 120px;
            background: #fff;
            border: 1.5px solid #e2e8f0;
            border-radius: 8px;
            padding: 7px 12px;
            color: #1e293b;
            outline: none;
            transition: border-color 0.18s;
        }
        .search-input:focus { border-color: #f59e0b; box-shadow: 0 0 0 3px rgba(245,158,11,0.15); }
        .search-input::placeholder { text-transform: none; font-weight: 400; color: #94a3b8; }

        .btn-go {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.78rem;
            font-weight: 700;
            background: #0f172a;
            color: #fbbf24;
            border: none;
            border-radius: 7px;
            padding: 8px 16px;
            cursor: pointer;
            transition: background 0.15s;
        }
        .btn-go:hover { background: #1e293b; }

        .lot-badge {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.72rem;
            font-weight: 700;
            background: #fef3c7;
            color: #92400e;
            border: 1px solid #fcd34d;
            border-radius: 6px;
            padding: 3px 10px;
        }

        .alert-success {
            background: #f0fdf4; border: 1px solid #86efac; border-left: 4px solid #22c55e;
            color: #166534; border-radius: 10px; padding: 12px 16px;
            font-size: 0.85rem; font-family: 'JetBrains Mono', monospace;
        }
        .alert-error {
            background: #fef2f2; border: 1px solid #fca5a5; border-left: 4px solid #ef4444;
            color: #991b1b; border-radius: 10px; padding: 12px 16px;
            font-size: 0.85rem; font-family: 'JetBrains Mono', monospace;
        }
        .field-error { color: #ef4444; font-size: 0.7rem; font-family: 'JetBrains Mono', monospace; margin-top: 4px; display: block; }

        @@media (max-width: 768px) {
            .cols-3 { grid-template-columns: 1fr; }
            .cols-2 { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">

    <!-- Nav -->
    <nav class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-800">
        <div class="max-w-5xl mx-auto px-6 h-12 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <span class="text-white font-bold text-base tracking-widest mono">PC<span class="text-amber-400">MS</span></span>
                <span class="text-slate-500 text-xs mono hidden sm:block">/ Extra Panel / Lot Master</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="bg-amber-950 text-amber-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mono hidden sm:inline-block">Asset Mgmt.</span>
                <span class="text-slate-400 text-xs mono hidden md:block">@Session["EmployeeNumber"]</span>
                <a href="@Url.Action("Extra","Admin")" class="text-xs font-semibold text-slate-400 hover:text-amber-400 border border-slate-700 hover:border-amber-600 px-3 py-1.5 rounded-md transition-colors mono">← Extra Panel</a>
                <a href="@Url.Action("Logout","Account")" class="text-xs font-semibold text-slate-400 hover:text-red-400 border border-slate-700 hover:border-red-600 px-3 py-1.5 rounded-md transition-colors mono">Logout</a>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8">

        <!-- Page header + search -->
        <div class="mb-6 flex items-start justify-between flex-wrap gap-4">
            <div>
                <h1 class="text-2xl font-extrabold text-slate-800 tracking-tight">Lot Master</h1>
                <p class="text-slate-400 text-xs mono mt-1">Asset Management · New Lot Entry</p>
            </div>

            <!-- Search existing lot by Lot No -->
            @using (Html.BeginForm("Load", "LotMaster", FormMethod.Get, new { @class = "search-bar" }))
            {
                <label class="text-xs mono text-slate-500 font-semibold whitespace-nowrap">Search Lot No.</label>
                <input type="text" name="lotNo" placeholder="e.g. C25"
                       value="@(Model.IsLoaded ? Model.LotNo : "")"
                       class="search-input" maxlength="50" />
                <button type="submit" class="btn-go">Go</button>
                if (Model.IsLoaded)
                {
                    <span class="lot-badge">Loaded: @Model.LotNo</span>
                }
            }
        </div>

        <!-- Alerts -->
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert-success mb-5">✔ @Model.SuccessMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert-error mb-5">✖ @Model.ErrorMessage</div>
        }

        <!-- Main form -->
        @using (Html.BeginForm("Insert", "LotMaster", FormMethod.Post))
        {
            @Html.AntiForgeryToken()

            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 sm:p-8 space-y-7">

                <!-- ── Lot No (manual entry) ── -->
                <div>
                    <p class="section-head">Lot Identification</p>
                    <div class="form-row" style="grid-template-columns: 220px 1fr;">
                        <div>
                            <label class="f-label">Lot No <span class="req">*</span></label>
                            @Html.TextBoxFor(m => m.LotNo, new
                            {
                                @class = "lot-field" + (ViewData.ModelState["LotNo"] != null && ViewData.ModelState["LotNo"].Errors.Count > 0 ? " is-invalid" : ""),
                                placeholder = "e.g. C25, L01",
                                maxlength = "50",
                                autocomplete = "off",
                                style = "text-transform:uppercase;"
                            })
                            @Html.ValidationMessageFor(m => m.LotNo, "", new { @class = "field-error" })
                        </div>                      
                    </div>
                </div>

                <!-- ── Equipment ── -->
                <div>
                    <p class="section-head">Equipment</p>
                    <div class="form-row cols-2">
                        <div>
                            <label class="f-label">Equip Type <span class="req">*</span></label>
                            <div class="select-wrap">
                                @Html.DropDownListFor(m => m.EquipType, Model.EquipTypeList, new
                                {
                                    @class = "f-select" + (ViewData.ModelState["EquipType"] != null && ViewData.ModelState["EquipType"].Errors.Count > 0 ? " is-invalid" : "")
                                })
                            </div>
                            @Html.ValidationMessageFor(m => m.EquipType, "", new { @class = "field-error" })
                        </div>
                        <div>
                            <label class="f-label">Equip. Sub Type</label>
                            <div class="select-wrap">
                                @Html.DropDownListFor(m => m.EquipSubType, Model.EquipSubTypeList, new { @class = "f-select" })
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Product Info ── -->
                <div>
                    <p class="section-head">Product Info</p>
                    <div class="form-row cols-3">
                        <div>
                            <label class="f-label">Brand Name</label>
                            <div class="select-wrap">
                                @Html.DropDownListFor(m => m.BrandName, Model.BrandList, new { @class = "f-select" })
                            </div>
                        </div>
                        <div>
                            <label class="f-label">Model Name</label>
                            @Html.TextBoxFor(m => m.ModelName, new { @class = "f-input", placeholder = "e.g. EliteBook 840" })
                        </div>
                        <div>
                            <label class="f-label">Quantity</label>
                            @Html.TextBoxFor(m => m.Quantity, new { @class = "f-input", placeholder = "0", type = "number", min = "0" })
                            @Html.ValidationMessageFor(m => m.Quantity, "", new { @class = "field-error" })
                        </div>
                    </div>
                </div>

                <!-- ── Warranty ── -->
                <div>
                    <p class="section-head">Warranty</p>
                    <div class="form-row cols-3">
                        <div>
                            <label class="f-label">Warranty Clause</label>
                            <div class="select-wrap">
                                @Html.DropDownListFor(m => m.WarrantyClause, Model.WarrantyClauseList, new { @class = "f-select" })
                            </div>
                        </div>
                        <div>
                            <label class="f-label">Warranty Start Date</label>
                            @Html.TextBoxFor(m => m.WarrantyStartDate, "{0:yyyy-MM-dd}", new { @class = "f-input", type = "date" })
                        </div>
                        <div>
                            <label class="f-label">Warranty End Date</label>
                            @Html.TextBoxFor(m => m.WarrantyEndDate, "{0:yyyy-MM-dd}", new { @class = "f-input", type = "date" })
                        </div>
                    </div>
                </div>

                <!-- ── AMC ── -->
                <div>
                    <p class="section-head">AMC Details</p>
                    <div class="form-row cols-3">
                        <div>
                            <label class="f-label">AMC Vendor</label>
                            @Html.TextBoxFor(m => m.AmcVendor, new { @class = "f-input", placeholder = "Vendor name" })
                        </div>
                        <div>
                            <label class="f-label">AMC Start Date</label>
                            @Html.TextBoxFor(m => m.AmcStartDate, "{0:yyyy-MM-dd}", new { @class = "f-input", type = "date" })
                        </div>
                        <div>
                            <label class="f-label">AMC End Date</label>
                            @Html.TextBoxFor(m => m.AmcEndDate, "{0:yyyy-MM-dd}", new { @class = "f-input", type = "date" })
                        </div>
                    </div>
                </div>

                <!-- ── PO ── -->
                <div>
                    <p class="section-head">Purchase Order</p>
                    <div class="form-row cols-3">
                        <div>
                            <label class="f-label">PO Vendor</label>
                            @Html.TextBoxFor(m => m.PoVendor, new { @class = "f-input", placeholder = "Vendor name" })
                        </div>
                        <div>
                            <label class="f-label">PO No</label>
                            @Html.TextBoxFor(m => m.PoNo, new { @class = "f-input", placeholder = "e.g. PO-2024-001" })
                        </div>
                        <div>
                            <label class="f-label">PO Date</label>
                            @Html.TextBoxFor(m => m.PoDate, "{0:yyyy-MM-dd}", new { @class = "f-input", type = "date" })
                        </div>
                    </div>
                </div>

                <!-- ── Specs ── -->
                <div>
                    <p class="section-head">Specifications</p>
                    <div class="form-row cols-2">
                        <div>
                            <label class="f-label">Spec 1</label>
                            @Html.TextBoxFor(m => m.Spec1, new { @class = "f-input", placeholder = "e.g. Intel i7-12th Gen" })
                        </div>
                        <div>
                            <label class="f-label">Spec 2</label>
                            @Html.TextBoxFor(m => m.Spec2, new { @class = "f-input", placeholder = "e.g. 16GB DDR5 RAM" })
                        </div>
                        <div>
                            <label class="f-label">Spec 3</label>
                            @Html.TextBoxFor(m => m.Spec3, new { @class = "f-input", placeholder = "e.g. 512GB NVMe SSD" })
                        </div>
                        <div>
                            <label class="f-label">Spec 4</label>
                            @Html.TextBoxFor(m => m.Spec4, new { @class = "f-input", placeholder = "e.g. Windows 11 Pro" })
                        </div>
                    </div>
                </div>

                <!-- ── Additional ── -->
                <div>
                    <p class="section-head">Additional Info</p>
                    <div class="form-row cols-2">
                        <div>
                            <label class="f-label">Remarks</label>
                            @Html.TextAreaFor(m => m.Remarks, new
                            {
                                @class = "f-input",
                                rows = "3",
                                placeholder = "Any additional notes…",
                                style = "resize:vertical;height:auto;"
                            })
                        </div>
                        <div>
                            <label class="f-label">Capitalisation Date</label>
                            @Html.TextBoxFor(m => m.CapitalisationDate, "{0:yyyy-MM-dd}", new { @class = "f-input", type = "date" })
                        </div>
                    </div>
                </div>

                <!-- Submit -->
                <div class="flex items-center justify-center pt-2 border-t border-slate-100">
                    <button type="submit" class="btn-insert">Insert Lot</button>
                </div>

            </div>
        }
    </main>

    <script>
        // Auto-uppercase the Lot No field as the user types
        document.getElementById('LotNo').addEventListener('input', function () {
            var pos = this.selectionStart;
            this.value = this.value.toUpperCase();
            this.setSelectionRange(pos, pos);
        });
    </script>
</body>
</html>
