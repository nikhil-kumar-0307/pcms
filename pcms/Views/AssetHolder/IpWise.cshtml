@* pcms/Views/AssetHolder/IpWise.cshtml *@
@{
    Layout = null;
    ViewBag.Title = "IP Wise Enquiry";

    var query = ViewBag.Query as string ?? "";
    var results = ViewBag.Results as List<pcms.Models.DTOs.IpWiseDTO>
                  ?? new List<pcms.Models.DTOs.IpWiseDTO>();
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
    :root {
        --coral: #FF6B6B;
        --pink: #FFB3BA;
        --blue: #4A90D9;
        --teal: #2EC4B6;
        --yellow: #FFD166;
        --bg: #F8F9FB;
        --card: #FFFFFF;
        --border: #E5E8EF;
        --text: #1E2432;
        --muted: #6B7280;
        --mono: 'JetBrains Mono', monospace;
        --sans: 'Plus Jakarta Sans', sans-serif;
    }

    .ip-page {
        font-family: var(--sans);
        background: var(--bg);
        min-height: 100vh;
        padding: 28px 32px;
        color: var(--text);
    }

    /* ── header ─────────────────────────────────────────────── */
    .ip-header {
        display: flex;
        align-items: center;
        gap: 14px;
        margin-bottom: 28px;
    }

    .ip-header-icon {
        width: 42px;
        height: 42px;
        background: linear-gradient(135deg, var(--blue), var(--teal));
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .ip-header-icon svg {
            color: #fff;
        }

    .ip-title {
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: -.3px;
    }

    .ip-subtitle {
        font-size: .78rem;
        color: var(--muted);
        margin-top: 2px;
        font-family: var(--mono);
    }

    /* ── breadcrumb ─────────────────────────────────────────── */
    .ip-breadcrumb {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
        font-family: var(--mono);
        font-size: .74rem;
        color: var(--muted);
    }

        .ip-breadcrumb a {
            color: var(--blue);
            text-decoration: none;
            font-weight: 600;
        }

            .ip-breadcrumb a:hover {
                text-decoration: underline;
            }

        .ip-breadcrumb .sep {
            color: var(--border);
        }

    /* ── search card ─────────────────────────────────────────── */
    .ip-search-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 24px 28px;
        margin-bottom: 28px;
        display: flex;
        align-items: flex-end;
        gap: 14px;
        flex-wrap: wrap;
    }

    .ip-field-wrap {
        display: flex;
        flex-direction: column;
        gap: 6px;
        flex: 1;
        min-width: 220px;
    }

    .ip-label {
        font-size: .73rem;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .05em;
        font-family: var(--mono);
    }

    .ip-input {
        height: 40px;
        border: 1.5px solid var(--border);
        border-radius: 8px;
        padding: 0 14px;
        font-family: var(--mono);
        font-size: .88rem;
        color: var(--text);
        background: #FAFBFC;
        transition: border-color .2s;
        outline: none;
        width: 100%;
    }

        .ip-input:focus {
            border-color: var(--blue);
            background: #fff;
        }

    .ip-btn {
        height: 40px;
        padding: 0 24px;
        border: none;
        border-radius: 8px;
        background: linear-gradient(135deg, var(--blue), var(--teal));
        color: #fff;
        font-family: var(--sans);
        font-weight: 600;
        font-size: .85rem;
        cursor: pointer;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: opacity .2s, transform .1s;
    }

        .ip-btn:hover {
            opacity: .88;
        }

        .ip-btn:active {
            transform: scale(.97);
        }

    /* ── hint chips below input ──────────────────────────────── */
    .ip-hint {
        font-family: var(--mono);
        font-size: .7rem;
        color: var(--muted);
        margin-top: -8px;
    }

        .ip-hint span {
            background: #EFF6FF;
            color: var(--blue);
            border: 1px solid #BFDBFE;
            border-radius: 4px;
            padding: 1px 7px;
            margin-right: 5px;
        }

    /* ── results header ──────────────────────────────────────── */
    .ip-results-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 12px;
    }

    .ip-results-title {
        font-size: .82rem;
        font-weight: 700;
        color: var(--muted);
        font-family: var(--mono);
        text-transform: uppercase;
        letter-spacing: .06em;
    }

    .ip-badge {
        background: #EFF6FF;
        color: var(--blue);
        font-family: var(--mono);
        font-size: .72rem;
        font-weight: 700;
        border-radius: 20px;
        padding: 3px 12px;
        border: 1px solid #BFDBFE;
    }

    /* ── table ───────────────────────────────────────────────── */
    .ip-table-wrap {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow-x: auto;
    }

    .ip-table {
        width: 100%;
        border-collapse: collapse;
        font-size: .8rem;
        table-layout: fixed;
    }

        .ip-table colgroup col:nth-child(1) {
            width: 110px;
        }
        /* Machine Num  */
        .ip-table colgroup col:nth-child(2) {
            width: 160px;
        }
        /* Model        */
        .ip-table colgroup col:nth-child(3) {
            width: 90px;
        }
        /* Dept         */
        .ip-table colgroup col:nth-child(4) {
            width: 150px;
        }
        /* Location     */
        .ip-table colgroup col:nth-child(5) {
            width: 150px;
        }
        /* Emp. Name    */
        .ip-table colgroup col:nth-child(6) {
            width: 70px;
        }
        /* Grade        */
        .ip-table colgroup col:nth-child(7) {
            width: 100px;
        }
        /* Emp Num      */
        .ip-table colgroup col:nth-child(8) {
            width: 140px;
        }
        /* Mac.Add      */

        .ip-table thead tr {
            background: #EFF6FF;
            border-bottom: 2px solid var(--border);
        }

        .ip-table th {
            padding: 10px 14px;
            font-family: var(--mono);
            font-size: .7rem;
            font-weight: 700;
            color: var(--blue);
            text-transform: uppercase;
            letter-spacing: .04em;
            text-align: left;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ip-table td {
            padding: 9px 14px;
            border-bottom: 1px solid #F0F2F6;
            font-family: var(--mono);
            font-size: .78rem;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .ip-table tbody tr:last-child td {
            border-bottom: none;
        }

        .ip-table tbody tr:hover {
            background: #F0F9FF;
        }

    /* highlight the searched IP in the result */
    .ip-highlight {
        background: #DBEAFE;
        color: #1D4ED8;
        border-radius: 4px;
        padding: 1px 6px;
        font-weight: 600;
    }

    /* ── empty state ─────────────────────────────────────────── */
    .ip-empty {
        padding: 56px 24px;
        text-align: center;
    }

    .ip-empty-icon {
        font-size: 2.2rem;
        margin-bottom: 10px;
    }

    .ip-empty-msg {
        font-size: .85rem;
        color: var(--muted);
        font-family: var(--mono);
    }
</style>

<div class="ip-page">

    @* ── Breadcrumb ── *@
    <div class="ip-breadcrumb">
        <a href="@Url.Action("Index", "AssetHolder")">Asset Enquiry</a>
        <span class="sep">›</span>
        <span>IP Wise</span>
    </div>

    @* ── Header ── *@
    <div class="ip-header">
        <div class="ip-header-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                      d="M5 12h14M12 5l7 7-7 7" />
            </svg>
        </div>
        <div>
            <div class="ip-title">IP Wise Details</div>
            <div class="ip-subtitle">Search by IP Address · partial match supported</div>
        </div>
    </div>

    @* ── Search Form ── *@
    @using (Html.BeginForm("IpWise", "AssetHolder", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        <div class="ip-search-card">
            <div class="ip-field-wrap">
                <label class="ip-label">IP Address</label>
                <input type="text"
                       name="searchQuery"
                       value="@query"
                       class="ip-input"
                       placeholder="e.g. 192.168.1.10  or  155.185"
                       autofocus />
                <div class="ip-hint">
                    Examples: <span>192.168.1.10</span><span>155.185</span><span>10.0</span>
                </div>
            </div>
            <button type="submit" class="ip-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                    <circle cx="11" cy="11" r="8" />
                    <path stroke-linecap="round" d="M21 21l-4.35-4.35" />
                </svg>
                Search
            </button>
        </div>
    }

    @* ── Results ── *@
    @if (!string.IsNullOrEmpty(query))
    {
        <div class="ip-results-header">
            <span class="ip-results-title">IP Wise Details</span>
            <span class="ip-badge">@results.Count record(s)</span>
        </div>

        <div class="ip-table-wrap">
            @if (results.Count == 0)
            {
                <div class="ip-empty">
                    <div class="ip-empty-icon">🔌</div>
                    <div class="ip-empty-msg">No machine found with IP matching "@query"</div>
                </div>
            }
            else
            {
                <table class="ip-table">
                    <colgroup>
                        <col />
                        <col />
                        <col />
                        <col />
                        <col />
                        <col />
                        <col />
                        <col />
                    </colgroup>
                    <thead>
                        <tr>
                            <th>Machine Num</th>
                            <th>Model</th>
                            <th>Dept</th>
                            <th>Location</th>
                            <th>Emp. Name</th>
                            <th>Grade</th>
                            <th>Emp Num</th>
                            <th>Mac.Add</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in results)
                        {
                            <tr>
                                <td title="@r.McNum">@r.McNum</td>
                                <td title="@r.MachineName">@r.MachineName</td>
                                <td title="@r.Dept">@r.Dept</td>
                                <td title="@r.CurrLoc">@r.CurrLoc</td>
                                <td title="@r.EmpName">@(string.IsNullOrEmpty(r.EmpName) ? "—" : r.EmpName)</td>
                                <td>@(string.IsNullOrEmpty(r.Grade) ? "X" : r.Grade)</td>
                                <td>@(string.IsNullOrEmpty(r.EmpNo) ? "XXXXXX" : r.EmpNo)</td>
                                <td>@(string.IsNullOrEmpty(r.MacAddress) ? "X" : r.MacAddress)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

</div>