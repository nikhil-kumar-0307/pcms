@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard — PCMS</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Syne', sans-serif;
        }

        .mono {
            font-family: 'JetBrains Mono', monospace;
        }

        .row-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 16px;
            border-bottom: 1px solid #e2e8f0;
            transition: background 0.15s;
        }

            .row-item:last-child {
                border-bottom: none;
            }

            .row-item:hover {
                background: #f8faff;
            }

        .link-main {
            color: #4f46e5;
            font-size: 0.875rem;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
            min-width: 220px;
        }

            .link-main:hover {
                text-decoration: underline;
                color: #3730a3;
            }

        .link-red {
            color: #dc2626;
            font-size: 0.875rem;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
            min-width: 220px;
        }

            .link-red:hover {
                text-decoration: underline;
                color: #991b1b;
            }

        .badge {
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            padding: 2px 8px;
            border-radius: 99px;
        }

        input[type=text] {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            border: 1.5px solid #cbd5e1;
            border-radius: 6px;
            padding: 5px 10px;
            background: #f8fafc;
            color: #1e293b;
            outline: none;
            width: 130px;
            transition: border-color 0.15s, box-shadow 0.15s;
        }

            input[type=text]:focus {
                border-color: #6366f1;
                box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
            }

        input.red-input:focus {
            border-color: #ef4444;
            box-shadow: 0 0 0 3px rgba(239,68,68,0.12);
        }

        .go-btn {
            font-size: 0.75rem;
            font-weight: 700;
            padding: 5px 14px;
            border-radius: 6px;
            text-decoration: none;
            letter-spacing: 0.04em;
            transition: background 0.15s;
        }

        .go-violet {
            background: #6366f1;
            color: white;
        }

            .go-violet:hover {
                background: #4f46e5;
            }

        .go-red {
            background: #ef4444;
            color: white;
        }

            .go-red:hover {
                background: #dc2626;
            }

        .label {
            font-size: 0.75rem;
            color: #94a3b8;
            font-family: 'JetBrains Mono', monospace;
        }

        .section-divider {
            height: 1px;
            background: linear-gradient(90deg, #6366f1 0%, transparent 100%);
            margin: 8px 0 0 0;
        }

        .section-divider-red {
            height: 1px;
            background: linear-gradient(90deg, #ef4444 0%, transparent 100%);
            margin: 8px 0 0 0;
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">

    <!-- Nav -->
    <nav class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-800">
        <div class="max-w-5xl mx-auto px-6 h-12 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <span class="text-white font-bold text-base tracking-widest mono">PC<span class="text-indigo-400">MS</span></span>
                <span class="text-slate-500 text-xs mono hidden sm:block">/ IT Help Desk</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="bg-indigo-950 text-indigo-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mono">Admin</span>
                <span class="text-slate-400 text-xs mono hidden md:block">@Session["EmployeeNumber"]</span>
                <a href="@Url.Action("Extra","Admin")" class="text-xs font-semibold bg-indigo-600 hover:bg-indigo-700 text-white px-3 py-1.5 rounded-md transition-colors mono">Extra Panel →</a>
                <a href="@Url.Action("Logout","Account")" class="text-xs font-semibold text-slate-400 hover:text-red-400 border border-slate-700 hover:border-red-600 px-3 py-1.5 rounded-md transition-colors mono">Logout</a>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 py-8">

        <!-- Header -->
        <div class="mb-6 flex items-baseline gap-4">
            <h1 class="text-xl font-bold text-slate-800 tracking-tight">Admin Dashboard</h1>
            <span class="text-xs text-slate-400 mono">IT Help Desk · Full Access</span>
        </div>

        <!-- Two-column layout like the original -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <!-- LEFT COLUMN -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-4 pt-4 pb-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-indigo-500 mono">Service & Complaints</span>
                    <div class="section-divider mt-1"></div>
                </div>

                <!-- List of Pending Service Requisitions -->
                <div class="row-item">
                    <a href="#" class="link-main">List of Pending Service Requisitions</a>
                </div>

                <!-- Register Service Requisition (Machine No.) -->
                <div class="row-item">
                    <a href="#" class="link-main">Register Service Requisition</a>
                    <input type="text" placeholder="Machine No." />
                    <a href="#" class="go-btn go-violet">Go</a>
                </div>

                <!-- Give Feedback -->
                <div class="row-item">
                    <a href="#" class="link-main">Give Feedback</a>
                    <input type="text" placeholder="Complain No." />
                    <a href="#" class="go-btn go-violet">Go</a>
                </div>

                <!-- Complaint Details (Complain No.) -->
                <div class="row-item">
                    <a href="#" class="link-main">Complaint Details</a>
                    <input type="text" placeholder="Complain No." />
                    <a href="#" class="go-btn go-violet">Go</a>
                </div>

                <!-- Complaint Details (Machine No. v1) -->
                <div class="row-item">
                    <a href="#" class="link-main">Complaint Details</a>
                    <input type="text" placeholder="Machine No." />
                    <a href="#" class="go-btn go-violet">Go</a>
                    <span class="label">v1</span>
                </div>

                <!-- Complaint Details New (Machine No. v2) -->
                <div class="row-item">
                    <a href="#" class="link-main">Complaint Details (New)</a>
                    <input type="text" placeholder="Machine No." />
                    <a href="#" class="go-btn go-violet">Go</a>
                    <span class="label">v2</span>
                </div>

                <!-- Latest Complaint's Status -->
                <div class="row-item">
                    <a href="#" class="link-main">Latest Complaint's Status</a>
                </div>

                <div class="px-4 pt-4 pb-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-red-500 mono">Admin Only</span>
                    <div class="section-divider-red mt-1"></div>
                </div>

                <!-- Update Machine Details -->
                <div class="row-item">
                    <a href="#" class="link-red">Update Machine Details</a>
                    <input type="text" placeholder="Machine No." class="red-input" />
                    <a href="#" class="go-btn go-red">Go</a>
                </div>
               
                <!-- Update Emp Details -->
                <div class="row-item">
                    <span class="link-red">Update Emp Details</span>
                    @using (Html.BeginForm("GoToUpdate", "EmployeeDetails", FormMethod.Get,
                            new { style = "display:inline-flex; align-items:center; gap:6px;" }))
                    {
            <input type="text" name="empNumber" placeholder="Emp No." class="red-input" required autocomplete="off" />
                            <button type="submit" class="go-btn go-red">Go</button>}
                </div>

                <!-- Update Asset Emp Details -->
                <div class="row-item">
                    <a href="#" class="link-red">Update Asset Emp Details</a>
                    <input type="text" placeholder="Emp No." class="red-input" />
                    <a href="#" class="go-btn go-red">Go</a>
                    <span class="label">p;</span>
                </div>

                <!-- Update/Delete Help Desk Engr -->
                <div class="row-item">
                    <a href="#" class="link-red">Update/Delete Help Desk Engr</a>
                    <input type="text" placeholder="Login Id" class="red-input" />
                    <a href="#" class="go-btn go-red">Go</a>
                </div>

                <!-- Buyback Detail -->
                <div class="row-item">
                    <a href="#" class="link-red">Buyback Detail</a>
                    <input type="text" placeholder="Emp No." class="red-input" />
                    <a href="#" class="go-btn go-red">Go</a>
                </div>

            </div>

            <!-- RIGHT COLUMN -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                <div class="px-4 pt-4 pb-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-indigo-500 mono">Asset Enquiry</span>
                    <div class="section-divider mt-1"></div>
                </div>

                <div class="row-item">
                    <span class="text-sm font-semibold text-slate-600 min-w-[120px]">Asset Enquiry</span>
                    <a href="#" class="link-main" style="min-width:unset">IP Wise</a>
                    <a href="#" class="link-main" style="min-width:unset">Machine Wise</a>
                </div>

                <div class="row-item">
                    <span class="text-sm font-semibold text-slate-600 min-w-[120px]">IT Asset History</span>
                    <a href="#" class="link-main" style="min-width:unset">Subnet Wise</a>
                    <a href="#" class="link-main" style="min-width:unset">Dept-Wise</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-main">Dept. Wise Asset Distribution</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-main">Detailed List of Service Requisitions for the Period</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-main">Brief Summary of Service Requisitions</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-main">View Feedback for the Period</a>
                </div>

                <div class="px-4 pt-4 pb-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-red-500 mono">Admin Only</span>
                    <div class="section-divider-red mt-1"></div>
                </div>

                <div class="row-item">
                    <span class="text-sm font-semibold text-slate-600 min-w-[120px]">Telephone Directory</span>
                    <a href="#" class="link-red" style="min-width:unset">Telephone Dir</a>
                    <a href="#" class="link-red" style="min-width:unset">Dept Wise</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-red">Reset Password of User</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-red">Upload Photo</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-red">Current Employee Detail</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-red">Teldir</a>
                </div>

                <div class="row-item border-t-2 border-indigo-100 mt-2">
                    <a href="@Url.Action("Extra","Admin")" class="link-main font-bold text-indigo-600">Extra →</a>
                </div>

            </div>
        </div>
    </main>
</body>
</html>
