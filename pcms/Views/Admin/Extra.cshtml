@{ Layout = null; }
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Extra Panel — PCMS Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Syne', sans-serif;
        }

        .mono {
            font-family: 'JetBrains Mono', monospace;
        }

        .row-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 16px;
            border-bottom: 1px solid #e2e8f0;
            flex-wrap: wrap;
            transition: background 0.15s;
        }

            .row-item:last-child {
                border-bottom: none;
            }

            .row-item:hover {
                background: #f0fdfa;
            }

        .link-teal {
            color: #0d9488;
            font-size: 0.875rem;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
        }

            .link-teal:hover {
                text-decoration: underline;
                color: #0f766e;
            }

        .link-amber {
            color: #b45309;
            font-size: 0.875rem;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
        }

            .link-amber:hover {
                text-decoration: underline;
                color: #92400e;
            }

        .link-red {
            color: #dc2626;
            font-size: 0.875rem;
            font-weight: 600;
            text-decoration: none;
            white-space: nowrap;
        }

            .link-red:hover {
                text-decoration: underline;
                color: #991b1b;
            }

        input[type=text] {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            border: 1.5px solid #cbd5e1;
            border-radius: 6px;
            padding: 5px 10px;
            background: #f8fafc;
            color: #1e293b;
            outline: none;
            width: 130px;
            transition: border-color 0.15s, box-shadow 0.15s;
        }

            input[type=text]:focus {
                border-color: #14b8a6;
                box-shadow: 0 0 0 3px rgba(20,184,166,0.12);
            }

        .go-btn {
            font-size: 0.75rem;
            font-weight: 700;
            padding: 5px 14px;
            border-radius: 6px;
            text-decoration: none;
            letter-spacing: 0.04em;
            transition: background 0.15s;
        }

        .go-teal {
            background: #14b8a6;
            color: white;
        }

            .go-teal:hover {
                background: #0d9488;
            }

        .label {
            font-size: 0.7rem;
            color: #f59e0b;
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
        }

        .sep {
            color: #cbd5e1;
            font-size: 0.7rem;
        }

        .section-divider-teal {
            height: 1px;
            background: linear-gradient(90deg, #14b8a6 0%, transparent 100%);
            margin: 8px 0 0 0;
        }

        .section-divider-amber {
            height: 1px;
            background: linear-gradient(90deg, #f59e0b 0%, transparent 100%);
            margin: 8px 0 0 0;
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">

    <!-- Nav -->
    <nav class="sticky top-0 z-50 bg-[#0f172a] border-b border-slate-800">
        <div class="max-w-5xl mx-auto px-6 h-12 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <span class="text-white font-bold text-base tracking-widest mono">PC<span class="text-teal-400">MS</span></span>
                <span class="text-slate-500 text-xs mono hidden sm:block">/ Extra Panel</span>
            </div>
            <div class="flex items-center gap-3">
                <span class="bg-teal-950 text-teal-300 text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mono hidden sm:inline-block">Admin › Extra</span>
                <span class="text-slate-400 text-xs mono hidden md:block">@Session["EmployeeNumber"]</span>
                <a href="@Url.Action("Index","Admin")" class="text-xs font-semibold text-slate-400 hover:text-teal-400 border border-slate-700 hover:border-teal-600 px-3 py-1.5 rounded-md transition-colors mono">← Back</a>
                <a href="@Url.Action("Logout","Account")" class="text-xs font-semibold text-slate-400 hover:text-red-400 border border-slate-700 hover:border-red-600 px-3 py-1.5 rounded-md transition-colors mono">Logout</a>
            </div>
        </div>
    </nav>

    <main class="max-w-5xl mx-auto px-6 py-8">

        <div class="mb-6 flex items-baseline gap-4">
            <h1 class="text-xl font-bold text-slate-800 tracking-tight">Extra Panel</h1>
            <span class="text-xs text-slate-400 mono">Advanced · Asset · Stock · System</span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <!-- LEFT COLUMN -->
            <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">

                <div class="px-4 pt-4 pb-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-teal-600 mono">Service Requisitions & Reports</span>
                    <div class="section-divider-teal mt-1"></div>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">List of Pending Service Requisitions</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Register Service Requisition</a>
                    <input type="text" placeholder="Machine No." />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Register Service Requisition</a>
                    <input type="text" placeholder="Emp No." />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Give Feedback</a>
                    <input type="text" placeholder="Complain No." />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Complaint Details</a>
                    <input type="text" placeholder="Complain No." />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Complaint Details</a>
                    <input type="text" placeholder="Machine No." />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Complaint Details</a>
                    <input type="text" placeholder="Machine No." />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Update Machine Details</a>
                    <input type="text" placeholder="Machine No." />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Update Emp Details</a>
                    <input type="text" placeholder="Emp No." />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Update Asset Emp Details</a>
                    <input type="text" placeholder="Emp No." />
                    <a href="#" class="go-btn go-teal">Go</a>                    
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Update/Delete Help Desk Engr</a>
                    <input type="text" placeholder="Login Id" />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Buyback Detail</a>
                    <input type="text" placeholder="Emp No." />
                    <a href="#" class="go-btn go-teal">Go</a>
                </div>

                <div class="px-4 pt-4 pb-2">
                    <span class="text-xs font-bold uppercase tracking-widest text-teal-600 mono">Telephone & User</span>
                    <div class="section-divider-teal mt-1"></div>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Telephone Dir</a>
                    <span class="sep">·</span>
                    <a href="#" class="link-teal">Telephone Dir Dept wise</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Latest Complaint's Status</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-red">Reset Password of User</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Upload Photo</a>
                </div>

                <div class="row-item">
                    <a href="#" class="link-teal">Teldir</a>
                    <span class="sep">·</span>
                    <a href="#" class="link-teal">Current Employee Detail</a>
                </div>

            </div>

            <!-- RIGHT COLUMN -->
            <div class="flex flex-col gap-6">

                <!-- Asset & Reports block -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="px-4 pt-4 pb-2">
                        <span class="text-xs font-bold uppercase tracking-widest text-amber-600 mono">Asset Enquiry & Reports</span>
                        <div class="section-divider-amber mt-1"></div>
                    </div>

                    <div class="row-item">
                        <span class="text-sm font-semibold text-slate-500 mono min-w-[90px] text-xs">Asset Enquiry</span>
                        <a href="#" class="link-amber">IP Wise</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Machine Wise</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Summary Report</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Brief Summary Report</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Complaint History (Dept-wise)</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">All</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Date wise report</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Dept Entry Form</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Update Dept name</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Active login not created</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">PCMS</a>
                    </div>

                    <div class="row-item">
                        <span class="text-sm font-semibold text-slate-500 mono min-w-[90px] text-xs">Dept wise Summary</span>
                        <a href="#" class="link-amber">Full</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">&lt;5 Yr</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">IT Pooled</a>
                    </div>

                    <div class="row-item">
                        <span class="text-sm font-semibold text-slate-500 mono min-w-[90px] text-xs">IT Asset History</span>
                        <a href="#" class="link-amber">Subnet Wise</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Asset Dept-Wise</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Emp list</a>
                    </div>

                    <div class="row-item">
                        <span class="text-sm font-semibold text-slate-500 mono min-w-[90px] text-xs">Dept. Wise Assets</span>
                        <a href="#" class="link-amber">Dept &amp; Lot</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Lot Wise Assets</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Lot-Wise Asset (*)</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Lot-Wise Asset (Date-wise)</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Lot Summary</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Cadre Wise Assets</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">General Assets</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Grade-Wise Asset</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Dept. Wise Asset Distribution</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">IT Asset Distribution</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Receipt Register</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Search Receipt Register</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">PC Prorata Calculation</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">IT Stock</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Stock Emp Wise</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Code Master</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-amber">Update Stock Type</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Asset Mgmt. (Lot Master)</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Update Machine IP</a>
                        <input type="text" placeholder="Machine No." style="border-color:#fcd34d;" />
                        <a href="#" class="go-btn" style="background:#f59e0b;color:white;">Go</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Detailed List of Service Requisitions for the Period</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">Attend by wise service Requisitions for the Period</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">View Feedback for the Period</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-amber">GP Flag Entry</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-red font-bold">PC Sl Num Edit</a>
                    </div>
                </div>

                <!-- Employee & Transferred -->
                <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
                    <div class="px-4 pt-4 pb-2">
                        <span class="text-xs font-bold uppercase tracking-widest text-teal-600 mono">Employee & Devices</span>
                        <div class="section-divider-teal mt-1"></div>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-teal">Addition of Employee Details</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-teal">Addition of Help Desk Engr</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-teal">List of Pending Devices of Transferred Employee</a>
                    </div>

                    <div class="row-item">
                        <span class="text-sm font-semibold text-slate-500 mono min-w-[70px] text-xs">ADM Detail</span>
                        <a href="#" class="link-teal">Comp</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-teal">Printer</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-teal">Laptop</a>
                    </div>

                    <div class="row-item">
                        <a href="#" class="link-teal">Hardware</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-teal">Receipt/Issue</a>
                        <span class="sep">·</span>
                        <a href="#" class="link-teal">Laptop Asset Transfer IOM</a>
                    </div>

                </div>

            </div>

        </div>
    </main>
</body>
</html>
